---
layout: default
---
<div class="post">
  <section class="hero reveal">
    <div class="hero__copy">
      {% if page.profile.kicker %}
        <p class="hero__kicker">{{ page.profile.kicker }}</p>
      {% endif %}

      <h1 class="hero__name">
        {% if site.title == 'blank' %}
          <span class="hero__name-emphasis">{{ site.first_name }}</span>
          {% if site.middle_name %}{{ site.middle_name }}{% endif %}
          {{ site.last_name }}
        {% else %}
          {{ site.title }}
        {% endif %}
      </h1>

      {% if page.subtitle %}
        <p class="hero__lead">{{ page.subtitle }}</p>
      {% endif %}

      {% if page.profile and page.profile.more_info %}
        <div class="hero__more-info">{{ page.profile.more_info }}</div>
      {% endif %}

      {% if page.social %}
        <div class="hero__social">{% social_links %}</div>
      {% endif %}
    </div>

    {% if page.profile and page.profile.image %}
      <div class="hero__media">
        <div class="hero__media-frame">
          {% assign profile_image_path = page.profile.image | prepend: 'assets/img/' %}
          {% capture profile_alt %}{% if page.profile.image_alt %}{{ page.profile.image_alt }}{% else %}{{ site.first_name }}{% if site.middle_name %} {{ site.middle_name }}{% endif %} {{ site.last_name }}{% endif %}{% endcapture %}
          {% include figure.liquid loading="eager" path=profile_image_path class="hero__image" sizes="(min-width: 576px) 180px, 50vw" alt=profile_alt cache_bust=true %}
        </div>
      </div>
    {% endif %}
  </section>

  <hr class="hero__rule">

  <article>
    <div class="hero__body reveal">{{ content }}</div>

    <!-- News -->
    {% if page.announcements and page.announcements.enabled %}
      <h2 class="section-heading reveal">
        <a href="{{ '/news/' | relative_url }}">news</a>
        <a class="section-heading__more" href="{{ '/news/' | relative_url }}">see all →</a>
      </h2>
      <div class="reveal">{% include news.liquid limit=true %}</div>
    {% endif %}

    <!-- Latest posts -->
    {% if page.latest_posts and page.latest_posts.enabled %}
      <h2 class="section-heading reveal">
        <a href="{{ '/blog/' | relative_url }}">latest posts</a>
        <a class="section-heading__more" href="{{ '/blog/' | relative_url }}">see all →</a>
      </h2>
      <div class="reveal">{% include latest_posts.liquid %}</div>
    {% endif %}

    <!-- Selected papers -->
    {% if page.selected_papers %}
      <h2 class="section-heading reveal">
        <a href="{{ '/publications/' | relative_url }}">selected publications</a>
        <a class="section-heading__more" href="{{ '/publications/' | relative_url }}">see all →</a>
      </h2>
      <div class="reveal">{% include selected_papers.liquid %}</div>
    {% endif %}

    {% if site.contact_note %}
      <p class="reveal mono-label" style="margin-top: 3rem;">{{ site.contact_note }}</p>
    {% endif %}

    {% if site.newsletter and site.newsletter.enabled and site.footer_fixed %}
      {% include newsletter.liquid center=true %}
    {% endif %}
  </article>
</div>
