<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 480 320" class="project-svg" role="img" aria-label="Density functional embedding: an active region embedded in an extended environment with polarization response.">
  <defs>
    <pattern id="dfe-lattice" patternUnits="userSpaceOnUse" width="38" height="38">
      <circle cx="19" cy="19" r="1.8" fill="currentColor" />
    </pattern>
    <mask id="dfe-cutout">
      <rect width="480" height="320" fill="white" />
      <circle cx="240" cy="160" r="94" fill="black" />
    </mask>
    <marker id="dfe-arrow" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6" markerHeight="6" orient="auto">
      <path d="M 0 0 L 10 5 L 0 10 z" fill="currentColor" opacity="0.6" />
    </marker>
  </defs>

  <!-- Environment lattice (muted dots, cut out around active region) -->
  <rect width="480" height="320" fill="url(#dfe-lattice)" opacity="0.20" mask="url(#dfe-cutout)" />

  <!-- Embedding boundary (dashed circle) -->
  <circle cx="240" cy="160" r="78" fill="none" stroke="currentColor" stroke-width="1.4" stroke-dasharray="5 4" opacity="0.55" />

  <!-- Polarization response arrows (environment -> active) -->
  <g stroke="currentColor" stroke-width="1.3" fill="none" opacity="0.55">
    <path d="M 90 92 Q 145 110 172 138" marker-end="url(#dfe-arrow)" />
    <path d="M 390 228 Q 335 210 308 182" marker-end="url(#dfe-arrow)" />
  </g>

  <!-- Active region: triangular molecule, accent teal -->
  <g>
    <!-- bonds -->
    <line x1="240" y1="132" x2="212" y2="182" stroke="#0e7c66" stroke-width="2.4" stroke-linecap="round" />
    <line x1="240" y1="132" x2="268" y2="182" stroke="#0e7c66" stroke-width="2.4" stroke-linecap="round" />
    <line x1="212" y1="182" x2="268" y2="182" stroke="#0e7c66" stroke-width="2.4" stroke-linecap="round" />
    <!-- electron density halos -->
    <circle cx="240" cy="132" r="13" fill="none" stroke="#0e7c66" stroke-width="1" opacity="0.45" />
    <circle cx="212" cy="182" r="13" fill="none" stroke="#0e7c66" stroke-width="1" opacity="0.45" />
    <circle cx="268" cy="182" r="13" fill="none" stroke="#0e7c66" stroke-width="1" opacity="0.45" />
    <!-- atoms -->
    <circle cx="240" cy="132" r="6.5" fill="#0e7c66" />
    <circle cx="212" cy="182" r="6.5" fill="#0e7c66" />
    <circle cx="268" cy="182" r="6.5" fill="#0e7c66" />
  </g>

  <!-- Mono labels -->
  <g font-family="JetBrains Mono, ui-monospace, monospace" font-size="11" letter-spacing="0.04em" fill="currentColor">
    <text x="240" y="252" text-anchor="middle" opacity="0.75" fill="#0e7c66">active</text>
    <text x="36" y="298" opacity="0.5">environment</text>
  </g>
</svg>
