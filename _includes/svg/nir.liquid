<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 480 320"
  class="project-svg"
  role="img"
  aria-label="Negative ion resonance: a quasi-bound state above the electron detachment threshold decaying into the continuum."
>
  <defs>
    <marker id="nir-arrow" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto">
      <path d="M 0 0 L 10 5 L 0 10 z" fill="#0e7c66" />
    </marker>
  </defs>

  <!-- Axes -->
  <g stroke="currentColor" stroke-width="1.2" fill="none" opacity="0.65">
    <line x1="70" y1="40" x2="70" y2="265" />
    <line x1="70" y1="265" x2="460" y2="265" />
    <polyline points="64,46 70,40 76,46" fill="currentColor" />
    <polyline points="454,259 460,265 454,271" fill="currentColor" />
  </g>

  <!-- E = 0 threshold (dashed) -->
  <line x1="70" y1="175" x2="460" y2="175" stroke="currentColor" stroke-width="1" stroke-dasharray="5 4" opacity="0.45" />

  <!-- V(r): Morse well, barrier, asymptote to E=0 continuum -->
  <path d="M 82 240 C 115 240 135 175 170 125 S 220 80 245 95 S 290 150 325 170 S 405 180 458 178"
        stroke="currentColor" stroke-width="2" fill="none" opacity="0.85" />

  <!-- Resonance: short horizontal energy level just above threshold, inside barrier-to-continuum shoulder -->
  <line x1="200" y1="148" x2="295" y2="148" stroke="#0e7c66" stroke-width="2.4" />
  <!-- Lorentzian-width hint below the level -->
  <path d="M 200 168 C 220 168 230 152 247 152 S 275 168 295 168"
        stroke="#0e7c66" stroke-width="1.3" fill="none" opacity="0.55" />

  <!-- Decay arrow: resonance leaks into the continuum -->
  <line x1="298" y1="148" x2="370" y2="148" stroke="#0e7c66" stroke-width="1.6" marker-end="url(#nir-arrow)" />

  <!-- Mono labels -->
  <g font-family="JetBrains Mono, ui-monospace, monospace" font-size="11" letter-spacing="0.04em" fill="currentColor">
    <text x="48" y="44" opacity="0.85">V(r)</text>
    <text x="468" y="282" opacity="0.85" text-anchor="end">r</text>
    <text x="78" y="170" opacity="0.55">E = 0</text>
    <text x="248" y="135" text-anchor="middle" fill="#0e7c66" font-size="10">resonance · Γ</text>
    <text x="378" y="140" fill="#0e7c66" font-size="10" opacity="0.85">decay</text>
  </g>
</svg>
